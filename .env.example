# ===========================================
# Required — no defaults, must be set
# ===========================================

# Site URL — your deployment domain.
# Also set this in:
#   - supabase/config.toml → site_url and additional_redirect_urls
#   - Supabase Dashboard → Auth → URL Configuration
# If using Vercel's default domain, use https://<project>.vercel.app
NEXT_PUBLIC_SITE_URL="https://your.domain"

# Supabase (Dashboard → Settings → API / API Keys)
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# VAPID push notifications (generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""

# Cron job authentication secret (any random string)
CRON_SECRET=""

# ===========================================
# Optional — pre-filled with defaults.
# Use as-is or change to fit your deployment.
# ===========================================

# App branding
NEXT_PUBLIC_APP_NAME="DOOOZ"
NEXT_PUBLIC_APP_DESCRIPTION="Family tasks, points, and multi-year adventures."
NEXT_PUBLIC_THEME_COLOR="#7c3aed"

# Locale (see README for supported locales)
NEXT_PUBLIC_DEFAULT_LOCALE="en"
NEXT_PUBLIC_LOCALE_COOKIE="doooz_locale"

# Synthetic email domain for child accounts (no actual email sent).
# Not used for real email delivery — matching your site domain is optional
# but recommended for consistency.
NEXT_PUBLIC_SYNTHETIC_EMAIL_DOMAIN="dooooz.invalid"

# VAPID push notification contact (mailto: URI).
# Used by push services to contact you in case of issues.
# Not strictly required to match your site domain, but recommended
# for consistency (e.g., mailto:noreply@your.domain).
VAPID_CONTACT_EMAIL="mailto:noreply@dooooz.invalid"

# Local storage key for family name
NEXT_PUBLIC_FAMILY_STORAGE_KEY="doooz_family_name"
