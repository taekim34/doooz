  "privacy.back_to_login": "Back to login",
  "privacy.intro": "Doooz is a family task gamification app. We respect your privacy and collect only the minimum data needed to run the service.",
  "privacy.last_updated": "Last updated: April 14, 2026",
  "privacy.link": "Privacy Policy",
  "privacy.section_changes_desc": "We may update this policy from time to time. Changes will be posted on this page with an updated date.",
  "privacy.section_changes_title": "Changes to this policy",
  "privacy.section_children_desc": "Children sign up without an email address. A parent must first create a family, then children join using an invite code. Children's data is limited to their display name and task activity within the family.",
  "privacy.section_children_title": "Children's data",
  "privacy.section_contact_desc": "For privacy questions, email: taekim@ww-w.ai",
  "privacy.section_contact_title": "Contact",
  "privacy.section_cookies_desc": "We use only essential session cookies for authentication (Supabase Auth) and locale preference. No tracking cookies, no analytics, no ads.",
  "privacy.section_cookies_title": "Cookies",
  "privacy.section_data_activity": "Activity data: task completions, points, badges, levels, streaks, characters",
  "privacy.section_data_child": "Child accounts: display name, password (hashed) — no email required. A synthetic email is generated server-side for authentication purposes only.",
  "privacy.section_data_family": "Family data: family name, invite code, timezone",
  "privacy.section_data_parent": "Parent accounts: email address, display name, password (hashed)",
  "privacy.section_data_title": "What data we collect",
  "privacy.section_deletion_desc": "You can delete your account from Settings at any time. Deletion is permanent — all your data is hard-deleted from the database. Family admins can delete the entire family and all member data.",
  "privacy.section_deletion_title": "Account deletion",
  "privacy.section_export_desc": "To request a copy of your data, contact us by email. We will provide your data in a standard format.",
  "privacy.section_export_title": "Data export",
  "privacy.section_opensource_desc": "Doooz is open source (Apache 2.0). You can review the full source code on GitHub.",
  "privacy.section_opensource_title": "Open source",
  "privacy.section_push_desc": "If you enable push notifications, your subscription endpoint is stored in our database. You can disable notifications at any time from your device settings.",
  "privacy.section_push_title": "Push notifications",
  "privacy.section_storage_desc": "Data is stored in Supabase (hosted on AWS). Access is controlled by Row Level Security (RLS) — each family can only see their own data.",
  "privacy.section_storage_title": "How data is stored",
  "privacy.section_why_desc": "All data is used solely to provide the Doooz service — assigning tasks, tracking progress, awarding points and badges. We do not sell, share, or use your data for advertising.",
  "privacy.section_why_title": "Why we collect it",
  "privacy.title": "Privacy Policy",
